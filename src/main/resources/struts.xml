<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
        "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>

    <!-- Constant Configuration -->
    <constant name="struts.devMode" value="true"/>
    <constant name="struts.enable.DynamicMethodInvocation" value="false"/>
    <constant name="struts.action.extension" value="action,,"/>
    <constant name="struts.objectFactory" value="spring"/>
    <constant name="struts.i18n.encoding" value="UTF-8"/>
    <constant name="struts.ui.theme" value="simple"/>
    <constant name="struts.multipart.maxSize" value="104857600"/>

    <!-- Package Configuration -->
    <package name="default" extends="struts-default,json-default">

        <!-- Default Action -->
        <default-action-ref name="index"/>

        <!-- User Actions -->
        <action name="user_*" class="userAction" method="{1}">
            <result name="list">/WEB-INF/jsp/user/list.jsp</result>
            <result name="add">/WEB-INF/jsp/user/add.jsp</result>
            <result name="edit">/WEB-INF/jsp/user/edit.jsp</result>
            <result name="success" type="redirectAction">user_list</result>
            <result name="json" type="json">
                <param name="root">dataMap</param>
            </result>
        </action>

        <!-- Index Action -->
        <action name="index">
            <result>/index.jsp</result>
        </action>

    </package>

</struts>
